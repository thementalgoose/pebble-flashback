{
  "name": "pebble-flashback",
  "author": "Jordan Fisher",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "@rebble/clay": "*",
    "pebble-api": "^0.2.2"
  },
  "pebble": {
    "displayName": "Flashback",
    "uuid": "6d1b717e-1f10-4da6-94c1-3347d6bec79f",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": false
    },
    "capabilities": [
      "configurable"
    ],
    "messageKeys": [
      "REQUEST_TYPE",
      "DATA_INDEX",
      "DATA_COUNT",
      "DATA_TITLE",
      "DATA_SUBTITLE",
      "DATA_EXTRA",
      "DATA_ROUND",
      "DATA_POINTS",
      "DATA_POSITION",
      "TIMELINE_PINS"
    ],
    "resources": {
      "media": [
        {
          "file": "images/icon_bw.png",
          "type": "bitmap",
          "name": "MENU_ICON",
          "memoryFormat": "1Bit",
          "menuIcon": true,
          "targetPlatforms": [
            "aplite",
            "diorite",
            "flint"
          ]
        },
        {
          "file": "images/icon_color.png",
          "type": "bitmap",
          "name": "MENU_ICON",
          "targetPlatforms": [
            "basalt",
            "chalk",
            "emery",
            "gabbro"
          ]
        }
      ]
    }
  }
}
